DATA_ROOT=data
OPENAI_PROVIDER=local
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=dummy-key
VISION_MODEL=gpt-4.1-mini
EDITOR_MODEL=gpt-4.1-mini
