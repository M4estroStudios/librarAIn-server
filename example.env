DATA_ROOT=data
OPENAI_PROVIDER=local
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=dummy-key
VISION_MODEL=gpt-4.1-mini
EDITOR_MODEL=gpt-4.1-mini
LM_STUDIO_SWAP_MODELS=true
LM_STUDIO_LOAD_TIMEOUT_SECONDS=600
TIMEOUT_SECONDS=120
RETRY_ATTEMPTS=3
RATE_LIMIT_PER_MINUTE=60
PAGE_RANGE_PER_THREAD=10
MAX_PARALLEL_REQUEST=4
OCR_LANGUAGES=it,en
OCR_USE_GPU=true
OCR_GPU_DEVICE=all
REASONING_EFFORT_VISION=low
REASONING_ENABLE_THINKING_VISION=false
REASONING_EFFORT_EDITOR=
REASONING_ENABLE_THINKING_EDITOR=false
MATCHER_EMBEDDING_MODEL=text-embedding-3-small
MATCHER_LLM_MODEL=
MATCHER_SIMILARITY_THRESHOLD=0.86
MATCHER_USE_AI=true
TIME_INDEX_LLM_MODEL=
TIME_INDEX_USE_LLM=true
TMP_KEEP_AFTER_SUCCESS=true

# --- HTTP server ---
# INGEST_HTTP_HOST=127.0.0.1
# INGEST_HTTP_PORT=8765
# Token statico richiesto su tutti gli endpoint /api/* (vivamente consigliato
# se il server e' esposto oltre localhost). Vuoto = nessuna autenticazione.
# INGEST_API_TOKEN=
# Numero massimo di ingest in parallelo (default 1; gli altri job restano in coda).
# INGEST_MAX_CONCURRENT_JOBS=1
# INGEST_MAX_UPLOAD_BYTES=536870912
